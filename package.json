{
	"name": "@cora-ui/monorepo",
	"version": "1.1.1",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"overrides": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"tailwindcss": "^4.0.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"build": "npm run build --workspaces --if-present",
		"version:bump": "npm version patch --workspaces --include-workspace-root --no-git-tag-version",
		"release": "npm publish --workspace=@cora-ui/react && git push origin main --tags && npm run version:bump && git push origin main"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "npm@11.8.0",
	"dependencies": {
		"esbuild-plugin-copy": "^2.1.1"
	}
}
