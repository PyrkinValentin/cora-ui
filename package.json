{
	"name": "@cora-ui/monorepo",
	"version": "1.1.31",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"overrides": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "^29.0.3",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"fast-glob": "^3.3.3",
		"rimraf": "^6.1.3",
		"rollup": "^4.62.2",
		"rollup-plugin-copy": "^3.5.0",
		"tailwindcss": "^4.0.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"build": "npm run build --workspaces --if-present",
		"release:version": "npm version patch --workspaces --include-workspace-root --no-git-tag-version --allow-same-version",
		"release": "npm run release:version && npm run build && git add . && git commit -m \"chore(release): bump version\" && node -e \"console.log(process.platform === 'win32' ? 'cmd /c' : ''); const v = require('./package.json').version; require('child_process').execSync('git tag v' + v)\" && git push origin main --tags && npm publish --workspaces --if-present"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "npm@11.8.0"
}
