{
	"name": "@cora-ui/react",
	"version": "1.1.13",
	"author": "Cora",
	"description": "Next-generation, high-performance React 19 UI component kit built on Base UI and Tailwind CSS v4 with native accessibility and zero runtime overhead.",
	"license": "MIT",
	"type": "module",
	"keywords": [
		"react",
		"react19",
		"nextjs",
		"cora-ui",
		"coraui",
		"base-ui",
		"tailwind",
		"tailwindcss",
		"tailwind-v4",
		"ui-kit",
		"design-system",
		"components",
		"react-components",
		"headless-ui",
		"accessibility",
		"a11y",
		"wai-aria",
		"wcag",
		"mcp-server",
		"high-performance"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PyrkinValentin/cora-ui.git"
	},
	"bugs": {
		"url": "https://github.com/PyrkinValentin/cora-ui/issues"
	},
	"homepage": "https://cora-ui.com",
	"main": "./build/index.js",
	"types": "./build/index.d.ts",
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"import": "./build/index.js",
			"default": "./build/index.js"
		},
		"./hooks": {
			"types": "./build/hooks/index.d.ts",
			"import": "./build/hooks/index.js"
		},
		"./utils": {
			"types": "./build/utils/index.d.ts",
			"import": "./build/utils/index.js"
		},
		"./styles": "./build/styles/styles.css"
	},
	"files": [
		"build"
	],
	"scripts": {
		"clean": "rimraf build",
		"build": "npm run clean && rollup -c"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^4.0.0"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0"
	},
	"sideEffects": [
		"**/*.css"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
